# ============================================================================
# Vendor Portal App — Frontend Environment Variables (vendor.cethos.com)
# ============================================================================
# These are BAKED INTO THE CLIENT BUNDLE at build time and are visible to
# anyone who inspects the browser. Never put secret keys here — only the
# Supabase anon key (which is safe by design) and public URLs.
#
# Where to set in production: Netlify → Site settings → Environment variables
# (Netlify site for vendor.cethos.com)
# ============================================================================

VITE_SUPABASE_URL=https://lmzoyezvsjgsxveoakdr.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_APP_URL=https://vendor.cethos.com
VITE_ADMIN_URL=https://portal.cethos.com


# === Sentry — error monitoring =============================================
# DSN is embedded in the client bundle (safe to expose publicly).
# Leave blank locally to disable Sentry entirely. Set in Netlify for prod.
VITE_SENTRY_DSN=

# Source-map upload at build time. Required only in CI / Netlify, not locally.
# Generate the auth token at https://sentry.io → Settings → Auth Tokens with
# org:read + project:releases + project:write scopes. Mark as secret.
SENTRY_ORG=cethos-solutions-inc
SENTRY_PROJECT=cethos-vendor-portal
SENTRY_AUTH_TOKEN=
