# ============================================================================
# Supabase Edge Functions — Server-Side Secrets
# ============================================================================
# These run INSIDE Supabase edge functions (Deno). They are NEVER exposed to
# the browser. DO NOT put them in Netlify or in any VITE_* var.
#
# Where to set in production (choose one):
#
#   Option A — Supabase Dashboard (recommended for humans):
#     Project Settings → Edge Functions → Manage secrets → Add secret
#     https://supabase.com/dashboard/project/lmzoyezvsjgsxveoakdr/settings/functions
#
#   Option B — Supabase CLI (recommended for CI/scripting):
#     supabase secrets set BREVO_API_KEY=xxx --project-ref lmzoyezvsjgsxveoakdr
#     supabase secrets set ANTHROPIC_API_KEY=xxx --project-ref lmzoyezvsjgsxveoakdr
#     (repeat for each secret below)
#
# To verify what's set:
#     supabase secrets list --project-ref lmzoyezvsjgsxveoakdr
#
# Note: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by the
# Supabase runtime into every edge function — you do NOT need to set them
# manually. They're listed here for reference only.
# ============================================================================

# --- Auto-injected by Supabase runtime (do not set manually) ---
# SUPABASE_URL=https://lmzoyezvsjgsxveoakdr.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=auto-injected
# SUPABASE_ANON_KEY=auto-injected

# --- Anthropic (Claude API) — used by cvp-prescreen-application, cvp-assess-test ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Brevo (transactional email) — used by every cvp-* function that emails ---
BREVO_API_KEY=xkeysib-xxx

# --- Twilio (SMS) — used by vendor-auth-otp-send, vendor-verify-phone ---
# Get from: https://console.twilio.com/ → Account Info
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
# E.164 format, e.g. +15551234567. Must be a Twilio-purchased number OR a
# verified caller ID on trial accounts.
TWILIO_FROM_NUMBER=+15551234567

# --- Public URLs (referenced by edge functions when building email links) ---
APP_URL=https://join.cethos.com
VENDOR_PORTAL_URL=https://vendor.cethos.com
ADMIN_PORTAL_URL=https://portal.cethos.com
